@model IEnumerable<caobaModeloFabricacion.Models.SeguimientoProduccion>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<form asp-action="Index" method="get" class="form-inline mb-3">
    <div class="form-group mr-2">
        <input type="text" name="searchString" class="form-control" placeholder="Buscar por código de producto" value="@Context.Request.Query["searchString"]" />
    </div>
    <div class="form-group mr-2">
        <select name="estado" class="form-control">
            <option value="">-- Filtrar por estado --</option>
            @foreach (var estadoItem in ViewBag.Estados as SelectList)
            {
                <option value="@estadoItem.Value" selected="@(estadoItem.Value == Context.Request.Query["estado"] ? "selected" : null)">
                    @estadoItem.Text
                </option>
            }
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Buscar</button>
</form>

<p>
    <a asp-action="Create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Estado)</th>
            <th>@Html.DisplayNameFor(model => model.Avance)</th>
            <th>@Html.DisplayNameFor(model => model.TiempoTrabajado)</th>
            <th>@Html.DisplayNameFor(model => model.MaterialConsumido)</th>
            <th>@Html.DisplayNameFor(model => model.FechaActualizacion)</th>
            <th>@Html.DisplayNameFor(model => model.Comentarios)</th>
            <th>@Html.DisplayNameFor(model => model.OrdenProduccion)</th>
            <th>@Html.DisplayNameFor(model => model.Operario)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Estado)</td>
            <td>@Html.DisplayFor(modelItem => item.Avance)</td>
            <td>@Html.DisplayFor(modelItem => item.TiempoTrabajado)</td>
            <td>@Html.DisplayFor(modelItem => item.MaterialConsumido)</td>
            <td>@Html.DisplayFor(modelItem => item.FechaActualizacion)</td>
            <td>@Html.DisplayFor(modelItem => item.Comentarios)</td>
            <td>@Html.DisplayFor(modelItem => item.OrdenProduccion.Id)</td>
            <td>@Html.DisplayFor(modelItem => item.Operario.Id)</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
