@model dynamic
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LayoutLogged.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Dashboard</h2>
        <div class="d-flex align-items-center">
           
           
        </div>
    </div>

    <div class="row text-white mb-4">
        <div class="col-md-3">
            <div class="p-4 bg-primary rounded shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4>12</h4>
                        <p>Órdenes en Proceso</p>
                    </div>
                    <i class="fas fa-hard-hat fs-2"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4 bg-success rounded shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4>35</h4>
                        <p>Órdenes Finalizadas</p>
                    </div>
                    <i class="fas fa-check fs-2"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4 bg-warning rounded shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4>22</h4>
                        <p>Índice Retrasos</p>
                    </div>
                    <i class="fas fa-hourglass-half fs-2"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4 bg-danger rounded shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4>13</h4>
                        <p>Órdenes Pendientes</p>
                    </div>
                    <i class="fas fa-clipboard-list fs-2"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Avance de Producción por Producto</h5>
                    <canvas id="barChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Estado de Órdenes de Producción</h5>
                    <canvas id="donutChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const barCtx = document.getElementById('barChart').getContext('2d');
    const barChart = new Chart(barCtx, {
        type: 'bar',
        data: {
            labels: ['P1', 'P2', 'P3', 'P4', 'P5'],
            datasets: [{
                label: 'Cantidad Producida',
                data: [12, 19, 3, 5, 2],
                backgroundColor: '#f97316'
            }]
        }
    });

    const donutCtx = document.getElementById('donutChart').getContext('2d');
    const donutChart = new Chart(donutCtx, {
        type: 'doughnut',
        data: {
            labels: ['En proceso', 'Finalizada', 'Pendiente'],
            datasets: [{
                label: 'Órdenes',
                data: [12, 35, 13],
                backgroundColor: ['#0d6efd', '#198754', '#ffc107']
            }]
        }
    });
</script>
